{
  "package_version": 2,
  "name": "cocos-mcp-plugin",
  "version": "0.1.0",
  "author": "wanwh",
  "editor": ">=3.8.6",
  "description": "A clean TypeScript Streamable HTTP MCP server for Cocos Creator.",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:capabilities": "node scripts/extract-cocos-capabilities.js",
    "watch": "tsc -p tsconfig.json -w",
    "test": "tsc -p tsconfig.test.json && node dist-test/test/run-tests.js"
  },
  "devDependencies": {
    "@cocos/creator-types": "^3.8.6",
    "@types/node": "^18.17.1",
    "typescript": "^5.8.2"
  },
  "panels": {
    "default": {
      "title": "Cocos Mcp Plugin Panel",
      "type": "dockable",
      "main": "./dist/panels/default/index.js",
      "size": {
        "min-width": 360,
        "min-height": 320,
        "width": 520,
        "height": 620
      }
    }
  },
  "contributions": {
    "menu": [
      {
        "path": "i18n:menu.extension/Cocos Mcp Plugin",
        "label": "Open Panel",
        "message": "open-panel"
      }
    ],
    "messages": {
      "open-panel": {
        "methods": [
          "openPanel"
        ]
      },
      "start-server": {
        "methods": [
          "startServer"
        ]
      },
      "stop-server": {
        "methods": [
          "stopServer"
        ]
      },
      "get-server-status": {
        "methods": [
          "getServerStatus"
        ]
      },
      "get-tools-list": {
        "methods": [
          "getToolsList"
        ]
      },
      "get-tool-exposure-config": {
        "methods": [
          "getToolExposureConfig"
        ]
      },
      "get-tool-exposure-summary": {
        "methods": [
          "getToolExposureSummary"
        ]
      },
      "update-tool-exposure-config": {
        "methods": [
          "updateToolExposureConfig"
        ]
      }
    },
    "scene": {
      "script": "./dist/scene.js",
      "methods": [
        "getCurrentSceneInfo",
        "getSceneHierarchy",
        "executeScript",
        "callRuntime"
      ]
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
